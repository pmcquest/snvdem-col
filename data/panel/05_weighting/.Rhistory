# Merge all these dfs
snwkcc_all <- as.data.frame(cbind(snwkcc_0[,3:4], snwkcc_1, snwkcc_2[,3:4], snwkcc_3[,3:4], snwkcc_4[,3:4], snwkcc_5[,3:4],
snwkcc_6[,3:4], snwkcc_7[,3:4], snwkcc_8[,3:4], snwkcc_9[,3:4], snwkcc_10[,3:4],
snwkcc_11[,3:4], snwkcc_12[,3:4], snwkcc_13[,3:4], snwkcc_14[,3:4], snwkcc_15[,3:4],
snwkcc_16[,3:4], snwkcc_17[,3:4], snwkcc_18[,3:4], snwkcc_19[,3:4], snwkcc_20[,3:4], snwkcc_21[,3:4]))
# Reordering columns
snwkcc_all <- select(snwkcc_all, country_text_id, year, v2clrgwkch_0_0, v2clrgwkch_0_1:last_col())
# Merge in the frequencies of coders who said sn elections were the same subnationally
snwkcc_alll <- merge(snlsffHPD[,1:3], snwkcc_all, by = c("country_text_id", "year"),
all.x = TRUE)
# Calculate proportions of CEs who chose each criterion
cnc_proportions <- snwkcc_alll %>%
mutate(pr_0 = v2clrgwkch_0_1/(v2clrgwkch_0_1 + v2clrgwkch_0_0 + snlsff_2),
pr_1 = v2clrgwkch_1_1/(v2clrgwkch_1_1 + v2clrgwkch_1_0 + snlsff_2),
pr_2 = v2clrgwkch_2_1/(v2clrgwkch_2_1 + v2clrgwkch_1_0 + snlsff_2),
pr_3 = v2clrgwkch_3_1/(v2clrgwkch_3_1 + v2clrgwkch_1_0 + snlsff_2),
pr_4 = v2clrgwkch_4_1/(v2clrgwkch_4_1 + v2clrgwkch_1_0 + snlsff_2),
pr_6 = v2clrgwkch_6_1/(v2clrgwkch_6_1 + v2clrgwkch_6_0 + snlsff_2),
pr_5 = v2clrgwkch_5_1/(v2clrgwkch_5_1 + v2clrgwkch_5_0 + snlsff_2),
pr_7 = v2clrgwkch_7_1/(v2clrgwkch_7_1 + v2clrgwkch_7_0 + snlsff_2),
pr_8 = v2clrgwkch_8_1/(v2clrgwkch_8_1 + v2clrgwkch_8_0 + snlsff_2),
pr_9 = v2clrgwkch_9_1/(v2clrgwkch_9_1 + v2clrgwkch_9_0 + snlsff_2),
pr_10 = v2clrgwkch_10_1/(v2clrgwkch_10_1 + v2clrgwkch_10_0 + snlsff_2),
pr_11 = v2clrgwkch_11_1/(v2clrgwkch_11_1 + v2clrgwkch_11_0 + snlsff_2),
pr_12 = v2clrgwkch_12_1/(v2clrgwkch_12_1 + v2clrgwkch_12_0 + snlsff_2),
pr_13 = v2clrgwkch_13_1/(v2clrgwkch_13_1 + v2clrgwkch_13_0 + snlsff_2),
pr_14 = v2clrgwkch_14_1/(v2clrgwkch_14_1 + v2clrgwkch_14_0 + snlsff_2),
pr_15 = v2clrgwkch_15_1/(v2clrgwkch_15_1 + v2clrgwkch_15_0 + snlsff_2),
pr_16 = v2clrgwkch_16_1/(v2clrgwkch_16_1 + v2clrgwkch_16_0 + snlsff_2),
pr_17 = v2clrgwkch_17_1/(v2clrgwkch_17_1 + v2clrgwkch_17_0 + snlsff_2),
pr_18 = v2clrgwkch_18_1/(v2clrgwkch_18_1 + v2clrgwkch_18_0 + snlsff_2),
pr_19 = v2clrgwkch_19_1/(v2clrgwkch_19_1 + v2clrgwkch_19_0 + snlsff_2),
pr_20 = v2clrgwkch_20_1/(v2clrgwkch_20_1 + v2clrgwkch_20_0 + snlsff_2),
pr_21 = v2clrgwkch_21_1/(v2clrgwkch_21_1 + v2clrgwkch_21_0 + snlsff_2))
cnc_proportions <- cnc_proportions[c(1:2, 48:69)]
# Full sample
colnames(cnc_proportions) <- c("country_text_id", "year", "Rural", "Urban", "Less development", "More development", "Inside capital", "Outside capital", "North", "South", "West", "East", "Civil unrest", "Illicit activity", "Sparse population", "Remote", "Indigenous", "Ruling party strong", "Ruling party weak", "Longer foreign rule", "Shorter foreign rule", "Recent foreign rule", "No foreign rule", "None of the above")
cn_table_long <- filter(cnc_proportions[,c(1:2, 3:24)], !is.na(Rural)) %>%
pivot_longer(cols = !c(country_text_id, year),
names_to = "dimension",
values_to = "weight")
install.packages("ggridges")
gc()
