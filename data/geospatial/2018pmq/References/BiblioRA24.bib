@article{marquardtIRTModelsExpertCoded2018,
  title = {{{IRT Models}} for {{Expert-Coded Panel Data}}},
  author = {Marquardt, Kyle L. and Pemstein, Daniel},
  date = {2018-10},
  journaltitle = {Political Analysis},
  volume = {26},
