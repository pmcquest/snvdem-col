@article{bernhardEconomicPerformanceInstitutional2001,
  title = {Economic {{Performance}}, {{Institutional Intermediation}}, and {{Democratic Survival}}},
  author = {Bernhard, Michael and Nordstrom, Timothy and Reenock, Christopher},
  date = {2001},
  journaltitle = {The Journal of Politics},
  volume = {63},
  number = {3},
  eprint = {2691713},
  eprinttype = {jstor},
  pages = {775--803},
  publisher = {[University of Chicago Press, Southern Political Science Association]},
  issn = {0022-3816},
  url = {https://www.jstor.org/stable/2691713},
  urldate = {2024-04-05},
  abstract = {The breakdown of democracies has long been associated with poor economic performance. This study attempts to determine whether different configurations of democratic institutions can mediate the effects of poor economic performance. Using an original data set that includes all democracies from the period 1919 to 1995, we use continuous-time duration analysis to test hypotheses derived from the literature on democratization. Specifically, we test the interaction of party system and the configuration of legislative and executive power (parliamentarism and presidentialism) with economic performance to explain the likelihood of breakdown. Results suggest that majoritarian variants of democracy are more resistant to economic contraction than pluralist ones. Under conditions of economic growth, pluralist democracies outperform majoritarian ones.},
  file = {G:\My Drive\Notes\Readings\Bernhard et al_2001_Economic Performance, Institutional Intermediation, and Democratic Survival.pdf}
}

@article{bernhardMakingEmbeddedKnowledge2017,
  title = {Making {{Embedded Knowledge Transparent}}: {{How}} the {{V-Dem Dataset Opens New Vistas}} in {{Civil Society Research}}},
  shorttitle = {Making {{Embedded Knowledge Transparent}}},
  author = {Bernhard, Michael and Jung, Dong-Joon and Tzelgov, Eitan and Coppedge, Michael and Lindberg, Staffan I.},
  date = {2017-06},
  journaltitle = {Perspectives on Politics},
  shortjournal = {Perspect. polit.},
  volume = {15},
  number = {2},
  pages = {342--360},
  issn = {1537-5927, 1541-0986},
  doi = {10.1017/S1537592717000056},
  url = {https://www.cambridge.org/core/product/identifier/S1537592717000056/type/journal_article},
  urldate = {2024-04-05},
  abstract = {We show how the V-Dem data opens new possibilities for studying civil society in comparative politics. We explain how V-Dem was able to extract embedded expert knowledge to create a novel set of civil society indicators for 173 countries from 1900 to the present. This data overcomes shortcomings in the basis on which inference has been made about civil society in the past by avoiding problems of sample bias that make generalization difficult or tentative. We begin with a discussion of the reemergence of civil society as a central concept in comparative politics. We then turn to the shortcomings of the existing data and discusses how the V-Dem data can overcome them. We introduce the new data, highlighting two new indices—the core civil society index (CCSI) and the civil society participation index (CSPI)—and explain how the individual indicators and the indices were created. We then demonstrate how the CCSI uses embedded expert knowledge to capture the development of civil society on the national level in Venezuela, Ghana, and Russia. We close by using the new indices to examine the dispute over whether post-communist civil society is “weak.” Time-series cross-sectional analysis using 2,999 country-year observations between 1989 and 2012 fails to find that post-communist civil society is substantially different from other regions, but that there are major differences between the post-Soviet subsample and other post-communist countries both in relation to other regions and each other.},
  langid = {english},
  file = {C:\Users\patri\Zotero\storage\SFUM2A53\Bernhard et al. - 2017 - Making Embedded Knowledge Transparent How the V-D.pdf}
}

