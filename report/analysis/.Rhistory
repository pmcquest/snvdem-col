val_label(survey$F_AGECAT, 99) <- NULL
survey$POL1DT[survey$POL1DT==99] <- NA
survey$F_AGECAT[survey$F_AGECAT==99] <- NA
survey$POL1DTf <- to_factor(survey$POL1DT, ordered = TRUE)
survey$F_AGECATf <- to_factor(survey$F_AGECAT, ordered = TRUE)
survey.w <- svydesign(ids = ~1, data = survey,
weights = survey$WEIGHT)
TrumpGuns <- as.data.frame(prop.table(svytable(~POL1DTf+F_AGECATf,
survey.w), margin = 2))
TrumpGuns <- TrumpGuns[1:8,]
barchart <- ggplot(TrumpGuns, aes(x=POL1DTf, y=Freq*100)) +
geom_bar(stat="identity", fill = "red") +
theme_light() +
theme(text = element_text(size = 36, face = "bold")) +
labs(title = "    Trump approval among those {closest_state}",
y = "Percent",
x = "Do you approve or disapprove of the way Donald Trump is handling his job as president?")
anichart <- barchart +
transition_states(F_AGECATf,
transition_length = 2,
state_length = 4) +
ease_aes('cubic-in-out')
animate(anichart, fps = 10, width = 900, height = 500, res = 35)
ggplotly(CulturalMap, width=1000, height=750, tooltip = c("x", "y", "colour", "frame", "ids")) %>%
animation_slider(currentvalue = list(prefix = " ", font = list(color="black", size=32))) %>%
animation_opts(frame = 700, transition = 700)
