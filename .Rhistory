row_spec(nrow(summary_table2), bold = TRUE, color = "white", background = "darkgray")
writeLines(summary_table2, "G:/Shared drives/snvdem/snvdem24/report/analysis/table3.html")
writeLines(k, "G:/Shared drives/snvdem/snvdem24/report/analysis/table3.html")
