select(2:3|9)
col_ts <- merge(col_ts, Bog, by = c("MPIO_CDPMP", "year"), all = TRUE)
# now make variables for ECDF
eCDF_4t5 <- ecdf(Bog$DisBog_4t5)
Bog$DisBog_4t5c <- eCDF_4t5(Bog$DisBog_4t5)
Bogc <- Bog %>%
select(1:2|4)
